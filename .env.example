# ---------- Logging ----------
SERVICE_NAME=<your-service-name>          # e.g., nba-report
LOG_DIR=<log-directory-path>              # where logs will be written

# ---------- PostgreSQL ----------
DB_HOST=<db-hostname>                     # default "localhost"
DB_PORT=<db-port-number>                  # default "5432"
DB_USER=<db-username>                     # default "postgres"
DB_PASS=<db-password>                     # default "postgres"
DB_NAME=<database-name>                   # database name

# ---------- Media ----------
SHARED_DIR=<shared-directory-path>              # where report artifacts will be saved

TEAM_LOGO_DIR=<team-logos-directory-path>       # for visual reports
VISUALS_FONT_PATH=<visuals-font-file-path>      # for visual reports
BACKGROUND_QUOTE_SERIES_PATH=<image-file-path>  # for visual reports
BACKGROUND_PRICE_WINDOW_PATH=<image-file-path>  # for visual reports

# ---------- RabbitMQ ----------
RABBITMQ_HOST=<rabbit-host>               # default "localhost"
RABBITMQ_PORT=<rabbit-port>               # default "5672"
RABBITMQ_USER=<rabbit-username>           # default "guest"
RABBITMQ_PASSWORD=<rabbit-password>       # default "guest"
RABBITMQ_VHOST=<rabbit-vhost>             # default "/"

# ---------- Exchange / Queues ----------
EXCHANGE_NAME=<exchange-name>             # e.g., polymarket.nba

QUEUE_TG_BOT=<queue-tg_bot>                 # queue name for Telegram bot
QUEUE_ORACLE=<queue-oracle>               # queue name for database oracle service
QUEUE_REPORT=<queue-report>               # queue name for report generator service

RK_REQUEST=<routing-key-request>          # routing key for request messages
RK_RESPONSE=<routing-key-response>        # routing key for response messages
